# Copy to .env and fill in real values. .env is git-ignored — never commit it.

# --- Chatbot (RAG) ---
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=recipebot2
OPENAI_CHAT_MODEL=gpt-4o-mini
RAG_RETRIEVER_K=4
RAG_FETCH_K=20
# Refuse (instead of hallucinating) when the best match scores below this (0..1):
RAG_MIN_SCORE=0.30
